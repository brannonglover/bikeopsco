# Database (Supabase — see DEPLOYMENT.md § Database connection fix checklist)
# Validate before deploy: npm run db:validate-env
# Runtime: Transaction pooler (port 6543). Username is postgres.[project-ref], not postgres.
DATABASE_URL="postgresql://postgres.[project-ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# Migrations / prisma migrate deploy: Session pooler (port 5432). Do NOT use db.*.supabase.co — unreachable from Vercel.
DIRECT_URL="postgresql://postgres.[project-ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require"

# Email (Resend)
RESEND_API_KEY="re_..."
# Fallback if RESEND_API_KEY doesn't load on Vercel: BIKEOPS_RESEND_API_KEY="re_..."
FROM_EMAIL="Your Shop <no-reply@yourshop.com>"

# SMS (Twilio)
# Get credentials from https://console.twilio.com
# You need a Twilio phone number that can send SMS and receive MMS (e.g. +1XXXXXXXXXX)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+15551234567"
# Inbound SMS webhook signature: must match the URL configured in Twilio (use ngrok URL locally).
# TWILIO_WEBHOOK_URL="https://your-domain.com/api/webhooks/twilio/sms"
# Optional: require ?secret= on GET /api/sms/test in production
# SMS_TEST_SECRET="random-string"

# Blob storage (for product images, bike images, chat attachments)
# Get from Vercel Dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
# If your Blob store is configured as Private, set: BLOB_ACCESS=private
# (Default is public; omit for public stores)
# BLOB_ACCESS=private

# Bike image search (optional - for "Search for image online" when adding bikes)
# Recommended: Serper for make/model-specific Google Images (2,500 free queries, no credit card at serper.dev)
SERPER_API_KEY="your_serper_key"
# Fallback: Unsplash for generic bike photos (unsplash.com/developers)
UNSPLASH_ACCESS_KEY="your_unsplash_access_key"

# Stripe
STRIPE_SECRET_KEY="sk_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Recurring monthly SaaS price: $39.99/mo after the 14-day free trial.
STRIPE_BIKEOPS_MONTHLY_PRICE_ID="price_..."
# Optional comma-separated tenant subdomains that own Bike Ops and should not see SaaS billing prompts.
# Defaults to bbm, matching bbm.bikeops.co.
# BIKEOPS_BILLING_EXEMPT_SUBDOMAINS="bbm"
# Card surcharge for online payments (covers Stripe fees). Set to 0 to disable.
# CARD_SURCHARGE_PERCENT=2.9
# CARD_SURCHARGE_FIXED_CENTS=30
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Staging (Vercel Preview / develop branch on dev.bikeops.co):
# NEXT_PUBLIC_APP_URL="https://dev.bikeops.co"
# NEXTAUTH_URL="https://dev.bikeops.co"
# ALLOW_CUSTOMER_NOTIFICATIONS="true"  # only on isolated staging DB + test recipients
# STAGING="true"                       # blocks customer email/SMS (alternative to VERCEL_ENV=preview)
# STAGING_TEST_EMAIL="you@example.com" # used by npm run db:seed:staging
# See docs/staging-environment.md for full setup.

# PostHog analytics (public browser token)
NEXT_PUBLIC_POSTHOG_TOKEN="phc_vKDFFaTih87w8hxDjhefDEiTtJBNdBqkKcB7Hc5SToT4"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
NEXT_PUBLIC_POSTHOG_SITE="bikeopsco"

# Optional
# Minutes after the last chat message before nudge emails (customer / staff). Default 10.
# CHAT_REMINDER_MINUTES=10
SHOP_NAME="Basement Bike Mechanic"
# Public booking form SMS consent copy (optional; defaults to SHOP_NAME-style fallback)
NEXT_PUBLIC_SHOP_NAME="Basement Bike Mechanic"
# Email to receive new booking notifications (defaults to ADMIN_EMAIL if not set)
SHOP_NOTIFY_EMAIL="you@example.com"
# Fallback IANA timezone when a shop has no timezone in Settings → Features (per-shop setting preferred).
# SHOP_TIMEZONE="America/New_York"
# IANA timezone for the shop — used by cron jobs to compute "today" correctly.
# Common US values: America/New_York | America/Chicago | America/Denver | America/Los_Angeles
# Default: America/New_York (Eastern)
# Also controls the vercel.json cron schedule — see README for UTC equivalents.
SHOP_TIMEZONE="America/New_York"

# Staff login (NextAuth)
NEXTAUTH_SECRET="generate-a-random-string-e-g-openssl-rand-base64-32"
# Optional: separate secret for signed customer status/chat/pay links (?access=). Falls back to NEXTAUTH_SECRET.
# CUSTOMER_JOB_ACCESS_SECRET="generate-another-random-string"
NEXTAUTH_URL="https://bikeops.co"

# Initial admin user (for seed only - creates first staff account)
# Run: ADMIN_EMAIL=you@example.com ADMIN_PASSWORD=yourpassword npm run db:seed
ADMIN_EMAIL="brannonglover@gmail.com"
ADMIN_PASSWORD="PkZheqdP/YuJ1Ah5ImsEVEDB+8wtLy4PPnie8PQAXLM="

# Platform admin (Bike Ops operator — view trial signups at app.bikeops.co/admin)
# Use a dedicated email/password, not a shop staff account.
PLATFORM_ADMIN_EMAIL="you@example.com"
PLATFORM_ADMIN_PASSWORD="choose-a-strong-password"

# Email sent when a new shop signs up for a trial (defaults to support@basementbikemechanic.com)
# PLATFORM_SIGNUP_NOTIFY_EMAIL="support@basementbikemechanic.com"

# Marketing site chat (bikeops.co widget → Quo / OpenPhone SMS)
# API key from Quo → Settings → API. US carrier registration required for SMS.
QUO_API_KEY=""
# Your Quo BUSINESS line in E.164 (+1...) — not your personal cell.
QUO_PHONE_NUMBER="+15551234567"
# Optional: PN… id for that line (filters webhooks to this inbox only)
# QUO_PHONE_NUMBER_ID="PNxxxxxxxx"
# Quo app webhook signing secret (Settings → Webhooks → Reveal signing secret)
QUO_WEBHOOK_SIGNING_KEY=""
# Optional: ?secret= for manual/API webhook testing only
# QUO_WEBHOOK_SECRET=""
# Webhook URL: https://app.bikeops.co/api/webhooks/quo/messages
# Email when someone starts a website chat (defaults to PLATFORM_SIGNUP_NOTIFY_EMAIL)
# SITE_CHAT_NOTIFY_EMAIL="you@example.com"
# Avoid unless required — can route sends through the wrong line
# QUO_USER_ID=""
# Set false to skip texting the visitor on each widget message
# SITE_CHAT_RELAY_SMS_TO_VISITOR=true

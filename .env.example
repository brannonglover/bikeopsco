# Database
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# Email (Resend)
RESEND_API_KEY="re_..."
# Fallback if RESEND_API_KEY doesn't load on Vercel: BIKEOPS_RESEND_API_KEY="re_..."
FROM_EMAIL="Your Shop <notifications@yourshop.com>"

# SMS (Twilio) - for customer progress notifications
# Get credentials from https://console.twilio.com
# You need a Twilio phone number that can send SMS (e.g. +1XXXXXXXXXX)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+15551234567"

# Blob storage (for product images and chat attachments)
# Get from Vercel Dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Stripe
STRIPE_SECRET_KEY="sk_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Card surcharge for online payments (covers Stripe fees). Set to 0 to disable.
# CARD_SURCHARGE_PERCENT=2.9
# CARD_SURCHARGE_FIXED_CENTS=30
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional
SHOP_NAME="Basement Bike Mechanic"

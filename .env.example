# Database - Supabase PostgreSQL
# Supabase Dashboard → Project Settings → Database → Connection string (URI)
# For Vercel: Supabase uses IPv6 by default; Vercel does not support IPv6.
# Enable the IPv4 add-on in Supabase (Project Settings → Database → IPv4 add-on, ~$4/mo).
# Add connection_limit=1 for serverless (Vercel) to avoid exhausting the pool
DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connect_timeout=30&connection_limit=1"

# Email - get API key from https://resend.com
RESEND_API_KEY="re_xxx"
# Sender – use your verified domain email. Display name is always "BBM Services".
FROM_EMAIL="support@basementbikemechanic.com"
SHOP_NAME="Basement Bike Mechanic"
# Receipt logo – optional. Full URL to your logo (e.g. https://yoursite.vercel.app/bbm-logo-wo.png). If empty, uses NEXT_PUBLIC_APP_URL + /bbm-logo-wo.png. Must be publicly reachable for images to load in emails.
SHOP_LOGO_URL=""

# Storage - Vercel Blob for product image uploads (Vercel Dashboard → Storage → Blob)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# Payments - Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
# App URL – used for payment redirects and receipt logo. For production: https://your-site.vercel.app. Logo in receipts loads from this URL when SHOP_LOGO_URL is empty.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

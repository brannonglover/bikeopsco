generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Customer {
  id               String           @id @default(cuid())
  firstName        String
  lastName         String?
  email            String?
  phone            String?
  address          String?
  notes            String?
  bikes            Bike[]
  jobs             Job[]
  conversations    Conversation[]
  magicLinkTokens  MagicLinkToken[]
  chatSessions     ChatSession[]
  pushTokens       PushToken[]
  reviewRequests   ReviewRequest[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Bike {
  id          String     @id @default(cuid())
  make        String
  model       String?
  /// null = infer regular vs e-bike from make/model when needed
  bikeType    BikeType?
  nickname    String?
  imageUrl    String?
  customerId  String
  customer    Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobBikes    JobBike[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([customerId])
}

model JobBike {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  make      String
  model     String?
  /// null = use linked customer bike or infer from make/model
  bikeType  BikeType?
  nickname  String?
  imageUrl  String?
  bikeId    String?
  bike      Bike?    @relation(fields: [bikeId], references: [id], onDelete: SetNull)
  sortOrder        Int       @default(0)
  completedAt      DateTime?
  waitingOnPartsAt DateTime?
  createdAt        DateTime  @default(now())
  workingOnJob Job?     @relation("WorkingOnBike")
  jobServices  JobService[]
  jobProducts  JobProduct[]

  @@index([jobId])
}

model Job {
  id                String       @id @default(cuid())
  bikeMake          String       // Legacy / summary – first bike or "Multiple"
  bikeModel         String       // Legacy / summary
  jobBikes          JobBike[]
  workingOnJobBikeId String?     @unique
  workingOnJobBike   JobBike?    @relation("WorkingOnBike", fields: [workingOnJobBikeId], references: [id], onDelete: SetNull)
  stage             Stage        @default(BOOKED_IN)
  deliveryType      DeliveryType @default(DROP_OFF_AT_SHOP)
  dropOffDate       DateTime?
  pickupDate        DateTime?
  collectionAddress     String?
  collectionWindowStart String?
  collectionWindowEnd   String?
  customerId        String?
  customer          Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  notes             String?
  internalNotes     String?
  customerNotes     String?
  cancellationReason String?
  completedAt       DateTime?
  archivedAt        DateTime?
  columnSortOrder   Float?
  paymentStatus     PaymentStatus @default(UNPAID)
  sentEmails        JobEmail[]
  sentSms           JobSms[]
  jobServices       JobService[]
  jobProducts       JobProduct[]
  payments          Payment[]
  conversations     Conversation[]
  reviewRequests    ReviewRequest[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model Payment {
  id                    String   @id @default(cuid())
  jobId                 String
  job                   Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  stripePaymentIntentId String?  @unique
  amount                Decimal  @db.Decimal(10, 2)
  currency              String   @default("usd")
  status                String
  paymentMethod         String?
  createdAt             DateTime @default(now())
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  REFUNDED
}

enum BikeType {
  REGULAR
  E_BIKE
}

model Service {
  id          String       @id @default(cuid())
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  /// Stable id for system-managed line items (e.g. collection fee)
  slug        String?      @unique
  isSystem    Boolean      @default(false)
  jobServices JobService[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model JobService {
  id                String   @id @default(cuid())
  jobId             String
  job               Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  serviceId         String?
  service           Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  /// Name for ad-hoc line items not linked to the service catalog
  customServiceName String?
  quantity          Int      @default(1)
  unitPrice         Decimal  @db.Decimal(10, 2)
  notes             String?
  /// Optional: which bike in the job this service is for
  jobBikeId         String?
  jobBike           JobBike? @relation(fields: [jobBikeId], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())
}

enum Stage {
  PENDING_APPROVAL
  BOOKED_IN
  RECEIVED
  WORKING_ON
  WAITING_ON_PARTS
  BIKE_READY
  COMPLETED
  CANCELLED
}

enum DeliveryType {
  DROP_OFF_AT_SHOP
  COLLECTION_SERVICE
}

model EmailTemplate {
  id           String        @id @default(cuid())
  slug         String        @unique
  name         String
  subject      String
  bodyHtml     String
  triggerType  String
  stage        Stage?
  deliveryType DeliveryType?
  delayDays    Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model JobEmail {
  id           String   @id @default(cuid())
  jobId        String
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  templateSlug String
  sentAt       DateTime @default(now())
  recipient    String
}

model JobSms {
  id           String   @id @default(cuid())
  jobId        String
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  templateSlug String
  sentAt       DateTime @default(now())
  recipient    String
}

model Product {
  id            String       @id @default(cuid())
  name          String
  description   String?
  imageUrl      String?
  price         Decimal      @db.Decimal(10, 2)
  stockQuantity Int          @default(0)
  supplier      String?
  jobProducts   JobProduct[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model JobProduct {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  unitPrice Decimal  @db.Decimal(10, 2)
  notes     String?
  /// Optional: which bike in the job this product is for
  jobBikeId String?
  jobBike   JobBike? @relation(fields: [jobBikeId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model Conversation {
  id                 String    @id @default(cuid())
  customerId         String
  customer           Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobId              String?
  job                Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  messages           Message[]
  chatReminderEmails ChatReminderEmail[]
  archived           Boolean   @default(false)
  /// Last time the customer sent a typing heartbeat (staff UI treats as “typing” if recent).
  customerTypingAt   DateTime?
  /// When staff last opened this thread (GET messages). Used for unread badge vs customer messages.
  staffLastReadAt    DateTime?
  /// When the customer last opened this thread (GET messages). Used for "Viewed" indicator on staff messages.
  customerLastReadAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Message {
  id                 String              @id @default(cuid())
  conversationId     String
  conversation       Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender             MessageSender
  body               String?
  /// Twilio inbound MessageSid — dedupes webhook retries
  smsSid             String?             @unique
  attachments        MessageAttachment[]
  reactions          MessageReaction[]
  chatReminderEmails ChatReminderEmail[]
  createdAt          DateTime            @default(now())
  editedAt           DateTime?
}

model MessageReaction {
  id          String        @id @default(cuid())
  messageId   String
  message     Message       @relation(fields: [messageId], references: [id], onDelete: Cascade)
  emoji       String
  reactorType MessageSender
  createdAt   DateTime      @default(now())

  @@unique([messageId, reactorType])
  @@index([messageId])
}

/// One nudge email per conversation + message + kind (so we do not repeat while that message is still last).
model ChatReminderEmail {
  id             String           @id @default(cuid())
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messageId      String
  message        Message          @relation(fields: [messageId], references: [id], onDelete: Cascade)
  kind           ChatReminderKind
  sentAt         DateTime         @default(now())

  @@unique([conversationId, messageId, kind])
  @@index([conversationId])
}

enum ChatReminderKind {
  NUDGE_CUSTOMER
  NUDGE_STAFF
}

model MessageAttachment {
  id        String    @id @default(cuid())
  messageId String?
  message   Message?  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  url       String
  filename  String
  mimeType  String
  createdAt DateTime  @default(now())
}

enum MessageSender {
  STAFF
  CUSTOMER
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  name         String?
  pushTokens   PushToken[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model PushToken {
  id         String    @id @default(cuid())
  token      String    @unique
  platform   String
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([customerId])
}

model MagicLinkToken {
  id        String   @id @default(cuid())
  token     String   @unique
  customerId String
  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ChatSession {
  id        String   @id @default(cuid())
  token     String   @unique
  customerId String
  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ReviewSettings {
  id                  String  @id @default("default")
  googleReviewUrl     String?
  yelpReviewUrl       String?
  googlePlaceId       String?
  googleRating        Float?
  googleReviewCount   Int?
  yelpRating          Float?
  yelpReviewCount     Int?
  featuredReviews     Json?   @default("[]")
}

model ReviewRequest {
  id              String    @id @default(cuid())
  token           String    @unique @default(cuid())
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  jobId           String?
  job             Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  recipientEmail  String
  recipientName   String?
  sentAt          DateTime  @default(now())
  googleClickedAt DateTime?
  yelpClickedAt   DateTime?
}

/// Historical revenue from outside the app (e.g. Square exports) for reporting and taxes.
model ImportedRevenue {
  id          String   @id @default(cuid())
  source      String   @default("SQUARE")
  occurredAt  DateTime
  amount      Decimal  @db.Decimal(10, 2)
  description String?
  /// Square payment id or other stable id — avoids duplicate rows on re-import
  externalId  String?  @unique
  createdAt   DateTime   @default(now())

  @@index([occurredAt])
  @@index([source])
}

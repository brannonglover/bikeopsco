generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Shop {
  id                         String   @id @default(cuid())
  name                       String
  subdomain                  String   @unique
  billingStatus              String   @default("trialing")
  trialEndsAt                DateTime?
  stripeCustomerId           String?  @unique
  stripeSubscriptionId       String?  @unique
  stripePriceId              String?
  stripeCurrentPeriodEnd     DateTime?
  stripeCancelAtPeriodEnd    Boolean  @default(false)
  stripeSubscriptionUpdatedAt DateTime?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  customers        Customer[]
  bikes            Bike[]
  jobs             Job[]
  jobBikes         JobBike[]
  payments         Payment[]
  services         Service[]
  jobServices      JobService[]
  emailTemplates   EmailTemplate[]
  jobEmails        JobEmail[]
  jobSms           JobSms[]
  products         Product[]
  jobProducts      JobProduct[]
  conversations    Conversation[]
  messages         Message[]
  messageReactions MessageReaction[]
  chatReminders    ChatReminderEmail[]
  messageAttachments MessageAttachment[]
  users            User[]
  pushTokens       PushToken[]
  magicLinkTokens  MagicLinkToken[]
  chatSessions     ChatSession[]
  reviewSettings   ReviewSettings[]
  appSettings      AppSettings[]
  waitlistEntries  WaitlistEntry[]
  waitlistBikes    WaitlistBike[]
  reviewRequests   ReviewRequest[]
  importedRevenue  ImportedRevenue[]
}

model Customer {
  id               String           @id @default(cuid())
  shopId           String
  shop             Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  firstName        String
  lastName         String?
  email            String?
  phone            String?
  smsConsent       Boolean          @default(false)
  smsConsentSource String?
  smsConsentUpdatedAt DateTime?
  address          String?
  notes            String?
  bikes            Bike[]
  jobs             Job[]
  conversations    Conversation[]
  waitlistEntries  WaitlistEntry[]  @relation("WaitlistCustomer")
  magicLinkTokens  MagicLinkToken[]
  chatSessions     ChatSession[]
  pushTokens       PushToken[]
  reviewRequests   ReviewRequest[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([shopId])
}

model Bike {
  id          String     @id @default(cuid())
  shopId      String
  shop        Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  make        String
  model       String?
  /// null = infer regular vs e-bike from make/model when needed
  bikeType    BikeType?
  nickname    String?
  imageUrl    String?
  customerId  String
  customer    Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobBikes    JobBike[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([customerId])
  @@index([shopId])
}

model JobBike {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  make      String
  model     String?
  /// null = use linked customer bike or infer from make/model
  bikeType  BikeType?
  nickname  String?
  imageUrl  String?
  bikeId    String?
  bike      Bike?    @relation(fields: [bikeId], references: [id], onDelete: SetNull)
  sortOrder        Int       @default(0)
  completedAt      DateTime?
  waitingOnPartsAt DateTime?
  createdAt        DateTime  @default(now())
  workingOnJob Job?     @relation("WorkingOnBike")
  jobServices  JobService[]
  jobProducts  JobProduct[]

  @@index([jobId])
  @@index([shopId])
}

model Job {
  id                String       @id @default(cuid())
  shopId            String
  shop              Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  bikeMake          String       // Legacy / summary – first bike or "Multiple"
  bikeModel         String       // Legacy / summary
  jobBikes          JobBike[]
  workingOnJobBikeId String?     @unique
  workingOnJobBike   JobBike?    @relation("WorkingOnBike", fields: [workingOnJobBikeId], references: [id], onDelete: SetNull)
  stage             Stage        @default(BOOKED_IN)
  deliveryType      DeliveryType @default(DROP_OFF_AT_SHOP)
  dropOffDate       DateTime?
  pickupDate        DateTime?
  collectionAddress     String?
  collectionWindowStart String?
  collectionWindowEnd   String?
  customerId        String?
  customer          Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  notes             String?
  internalNotes     String?
  customerNotes     String?
  cancellationReason String?
  completedAt       DateTime?
  archivedAt        DateTime?
  columnSortOrder   Float?
  paymentStatus     PaymentStatus @default(UNPAID)
  sentEmails        JobEmail[]
  sentSms           JobSms[]
  jobServices       JobService[]
  jobProducts       JobProduct[]
  payments          Payment[]
  conversations     Conversation[]
  reviewRequests    ReviewRequest[]
  promotedWaitlistEntries WaitlistEntry[] @relation("WaitlistPromotedJob")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([shopId])
}

model Payment {
  id                    String   @id @default(cuid())
  shopId                String
  shop                  Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  jobId                 String
  job                   Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  stripePaymentIntentId String?
  amount                Decimal  @db.Decimal(10, 2)
  currency              String   @default("usd")
  status                String
  paymentMethod         String?
  createdAt             DateTime @default(now())

  @@unique([shopId, stripePaymentIntentId])
  @@index([shopId])
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  REFUNDED
}

enum BikeType {
  REGULAR
  E_BIKE
}

model Service {
  id          String       @id @default(cuid())
  shopId      String
  shop        Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  /// Stable id for system-managed line items (e.g. collection fee)
  slug        String?
  isSystem    Boolean      @default(false)
  jobServices JobService[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([shopId, slug])
  @@index([shopId])
}

model JobService {
  id                String   @id @default(cuid())
  shopId            String
  shop              Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  jobId             String
  job               Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  serviceId         String?
  service           Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  /// Name for ad-hoc line items not linked to the service catalog
  customServiceName String?
  quantity          Int      @default(1)
  unitPrice         Decimal  @db.Decimal(10, 2)
  notes             String?
  /// Optional: which bike in the job this service is for
  jobBikeId         String?
  jobBike           JobBike? @relation(fields: [jobBikeId], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())

  @@index([shopId])
}

enum Stage {
  PENDING_APPROVAL
  BOOKED_IN
  RECEIVED
  WORKING_ON
  WAITING_ON_CUSTOMER
  WAITING_ON_PARTS
  BIKE_READY
  COMPLETED
  CANCELLED
}

enum DeliveryType {
  DROP_OFF_AT_SHOP
  COLLECTION_SERVICE
}

model EmailTemplate {
  id           String        @id @default(cuid())
  shopId       String
  shop         Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  slug         String
  name         String
  subject      String
  bodyHtml     String
  triggerType  String
  stage        Stage?
  deliveryType DeliveryType?
  delayDays    Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([shopId, slug])
  @@index([shopId])
}

model JobEmail {
  id           String   @id @default(cuid())
  shopId       String
  shop         Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  jobId        String
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  templateSlug String
  sentAt       DateTime @default(now())
  recipient    String

  @@index([shopId])
}

model JobSms {
  id           String   @id @default(cuid())
  shopId       String
  shop         Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  jobId        String
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  templateSlug String
  sentAt       DateTime @default(now())
  recipient    String

  @@index([shopId])
}

model Product {
  id            String       @id @default(cuid())
  shopId        String
  shop          Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  imageUrl      String?
  price         Decimal      @db.Decimal(10, 2)
  stockQuantity Int          @default(0)
  supplier      String?
  jobProducts   JobProduct[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([shopId])
}

model JobProduct {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  unitPrice Decimal  @db.Decimal(10, 2)
  notes     String?
  /// Optional: which bike in the job this product is for
  jobBikeId String?
  jobBike   JobBike? @relation(fields: [jobBikeId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([shopId])
}

model Conversation {
  id                 String    @id @default(cuid())
  shopId             String
  shop               Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId         String
  customer           Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobId              String?
  job                Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  messages           Message[]
  chatReminderEmails ChatReminderEmail[]
  archived           Boolean   @default(false)
  /// Last time the customer sent a typing heartbeat (staff UI treats as “typing” if recent).
  customerTypingAt   DateTime?
  /// When staff last opened this thread (GET messages). Used for unread badge vs customer messages.
  staffLastReadAt    DateTime?
  /// When the customer last opened this thread (GET messages). Used for "Viewed" indicator on staff messages.
  customerLastReadAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([shopId])
}

model Message {
  id                 String              @id @default(cuid())
  shopId             String
  shop               Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  conversationId     String
  conversation       Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender             MessageSender
  body               String?
  /// Twilio inbound MessageSid — dedupes webhook retries
  smsSid             String?
  attachments        MessageAttachment[]
  reactions          MessageReaction[]
  chatReminderEmails ChatReminderEmail[]
  createdAt          DateTime            @default(now())
  editedAt           DateTime?

  @@unique([shopId, smsSid])
  @@index([shopId])
}

model MessageReaction {
  id          String        @id @default(cuid())
  shopId      String
  shop        Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  messageId   String
  message     Message       @relation(fields: [messageId], references: [id], onDelete: Cascade)
  emoji       String
  reactorType MessageSender
  createdAt   DateTime      @default(now())

  @@unique([messageId, reactorType])
  @@index([messageId])
  @@index([shopId])
}

/// One nudge email per conversation + message + kind (so we do not repeat while that message is still last).
model ChatReminderEmail {
  id             String           @id @default(cuid())
  shopId         String
  shop           Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messageId      String
  message        Message          @relation(fields: [messageId], references: [id], onDelete: Cascade)
  kind           ChatReminderKind
  sentAt         DateTime         @default(now())

  @@unique([conversationId, messageId, kind])
  @@index([conversationId])
  @@index([shopId])
}

enum ChatReminderKind {
  NUDGE_CUSTOMER
  NUDGE_STAFF
}

model MessageAttachment {
  id        String    @id @default(cuid())
  shopId    String
  shop      Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  messageId String?
  message   Message?  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  url       String
  filename  String
  mimeType  String
  createdAt DateTime  @default(now())

  @@index([shopId])
}

enum MessageSender {
  STAFF
  CUSTOMER
  SYSTEM
}

model User {
  id           String      @id @default(cuid())
  shopId       String
  shop         Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  email        String
  passwordHash String
  name         String?
  pushTokens   PushToken[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([shopId, email])
  @@index([shopId])
}

model PushToken {
  id         String    @id @default(cuid())
  shopId     String
  shop       Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  token      String    @unique
  platform   String
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([customerId])
  @@index([shopId])
}

model MagicLinkToken {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  token     String   @unique
  customerId String
  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([shopId])
}

model ChatSession {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  token     String   @unique
  customerId String
  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([shopId])
}

model ReviewSettings {
  id                  String  @id @default(cuid())
  shopId              String
  shop                Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  googleReviewUrl     String?
  yelpReviewUrl       String?
  googlePlaceId       String?
  googleRating        Float?
  googleReviewCount   Int?
  yelpRating          Float?
  yelpReviewCount     Int?
  featuredReviews     Json    @default("[]")

  @@unique([shopId])
  @@index([shopId])
}

model AppSettings {
  id                       String   @id @default(cuid())
  shopId                   String
  shop                     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  /// When false: new booking requests go to the waitlist instead of creating a job.
  bookingsEnabled          Boolean  @default(true)
  /// Maximum number of bikes allowed to be active (RECEIVED + WORKING_ON) before new bookings are waitlisted.
  maxActiveBikes           Int      @default(5)
  collectionServiceEnabled Boolean  @default(true)
  /// Collection eligibility radius, in miles
  collectionRadiusMiles    Float    @default(5)
  /// Collection fee (standard bike), USD
  collectionFeeRegular     Decimal  @db.Decimal(10, 2) @default(20)
  /// Collection fee (e-bike), USD
  collectionFeeEbike       Decimal  @db.Decimal(10, 2) @default(30)
  notifyCustomerEnabled    Boolean  @default(true)
  chatEnabled              Boolean  @default(true)
  reviewsEnabled           Boolean  @default(true)
  logoUrl                  String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@unique([shopId])
  @@index([shopId])
}

enum WaitlistStatus {
  WAITING
  PROMOTED
  CANCELLED
}

model WaitlistEntry {
  id                   String         @id @default(cuid())
  shopId               String
  shop                 Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  status               WaitlistStatus @default(WAITING)
  customerId           String?
  customer             Customer?      @relation("WaitlistCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  /// Snapshot of contact details from the booking request.
  firstName            String
  lastName             String
  email                String
  phone                String
  address              String?
  deliveryType         DeliveryType   @default(DROP_OFF_AT_SHOP)
  dropOffDate          DateTime?
  pickupDate           DateTime?
  collectionAddress    String?
  collectionWindowStart String?
  collectionWindowEnd  String?
  customerNotes        String?
  /// Array of Service ids selected in the booking widget (catalog items only).
  serviceIds           Json?          @default("[]")
  bikes                WaitlistBike[]
  promotedJobId        String?
  promotedJob          Job?           @relation("WaitlistPromotedJob", fields: [promotedJobId], references: [id], onDelete: SetNull)
  promotedAt           DateTime?
  archivedAt           DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([status, createdAt])
  @@index([customerId])
  @@index([shopId])
}

model WaitlistBike {
  id             String        @id @default(cuid())
  shopId         String
  shop           Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  waitlistEntryId String
  waitlistEntry  WaitlistEntry @relation(fields: [waitlistEntryId], references: [id], onDelete: Cascade)
  make           String
  model          String?
  bikeType       BikeType?
  sortOrder      Int           @default(0)
  createdAt      DateTime      @default(now())

  @@index([waitlistEntryId])
  @@index([shopId])
}

model ReviewRequest {
  id              String    @id @default(cuid())
  shopId          String
  shop            Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  token           String    @unique @default(cuid())
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  jobId           String?
  job             Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  recipientEmail  String
  recipientName   String?
  sentAt          DateTime  @default(now())
  googleClickedAt DateTime?
  yelpClickedAt   DateTime?

  @@index([shopId])
}

/// Historical revenue from outside the app (e.g. Square exports) for reporting and taxes.
model ImportedRevenue {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  source      String   @default("SQUARE")
  occurredAt  DateTime
  amount      Decimal  @db.Decimal(10, 2)
  description String?
  /// Square payment id or other stable id — avoids duplicate rows on re-import
  externalId  String?
  createdAt   DateTime   @default(now())

  @@unique([shopId, externalId])
  @@index([occurredAt])
  @@index([source])
  @@index([shopId])
}

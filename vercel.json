{
  "installCommand": "npm install --legacy-peer-deps",
  "crons": [
    {
      "path": "/api/cron/send-follow-ups",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/send-appointment-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/chat-reminders",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/staff-booking-reminders",
      "schedule": "0 12,13 * * *"
    }
  ]
}
